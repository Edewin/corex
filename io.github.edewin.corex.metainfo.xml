  <name>CoreX - Hardware Monitor</name>
  <developer id="io.github.edewin">
    <name>Eduard Soltuzu</name>
  </developer>
  <summary>Real-time hardware monitoring with an always-on-top overlay widget</summary>

  <description>
    <p>CoreX is a lightweight hardware monitor for Linux that keeps you informed about your system's health at all times.</p>
    <ul>
      <li>Monitors all sensors on your PC — CPU temperature, GPU temperature, fan speeds, voltages, and more</li>
      <li>Displays real-time CPU and RAM usage with clear, readable graphs</li>
      <li>Includes an always-on-top overlay widget — visible while gaming, working, or browsing, without switching windows</li>
      <li>Minimal resource footprint — CoreX watches your system without slowing it down</li>
      <li>Clean, native Linux interface built with PyQt6</li>
    </ul>
  </description>

  <keywords>
    <keyword>hardware monitor</keyword>
    <keyword>system monitor</keyword>
    <keyword>sensor</keyword>
    <keyword>sensors</keyword>
    <keyword>cpu</keyword>
    <keyword>gpu</keyword>
    <keyword>widget</keyword>
    <keyword>always-on-top</keyword>
  </keywords>

